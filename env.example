# -------------------------------
# Core App (required )
# -------------------------------
FT_ENV=production
FT_APP_NAME=FinTracker
FT_APP_VERSION=1.0.0
FT_BASE_URL=https://fin.example.com
FT_SESSION_SECRET=replace-with-a-long-random-secret
FT_EXTERNAL_PASSWORD_RESET_URL=https://accounts.example.com/reset

# -------------------------------
# Authentication / Keycloak (optional)
# -------------------------------
FT_KEYCLOAK_URL=https://sso.example.com
FT_KEYCLOAK_REALM=fintracker
FT_CLIENT_ID=fintracker-web
FT_KEYCLOAK_ADMIN_ROLES=fintracker-admin,admin
FT_KEYCLOAK_ADMIN_GROUPS=/fintracker-admin,fintracker-admin
FT_AUTH_ENABLED=true
FT_AUTH_PROVIDER=keycloak
FT_AUTH_ALLOW_LOCAL_LOGIN=true

# -------------------------------
# Bootstrap Admin (optional)
# -------------------------------
FT_DEFAULT_ADMIN_USERNAME=admin
FT_DEFAULT_ADMIN_PASSWORD=ChangeMeNow123
FT_DEFAULT_ADMIN_EMAIL=admin@example.com

# -------------------------------
# Database (required)
# -------------------------------
FT_MONGO_URI=mongodb://mongodb:27017
FT_MONGO_DB_NAME=fintracker
FT_DB_ENABLED=true

# -------------------------------
# Admin Application Defaults (optional)
# -------------------------------
FT_APP_LOGO_URL=/static/uploads/logos/logo.png
FT_SUPPORT_EMAIL=support@example.com
FT_SUPPORT_PHONE=+1-800-123-4567
FT_MAINTENANCE_MODE=false
FT_MAINTENANCE_MESSAGE=Scheduled maintenance in progress

# -------------------------------
# SMTP (optional)
# -------------------------------
FT_SMTP_ENABLED=false
FT_SMTP_HOST=smtp.example.com
FT_SMTP_PORT=587
FT_SMTP_USERNAME=mailer@example.com
FT_SMTP_PASSWORD=app-password-here
FT_SMTP_FROM=no-reply@example.com
FT_SMTP_TLS=true

# -------------------------------
# Telegram (optional)
# -------------------------------
FT_TELEGRAM_ENABLED=false
FT_TELEGRAM_BOT_USERNAME=fintracker_bot
FT_TELEGRAM_BOT_TOKEN=123456:telegram-token
FT_TELEGRAM_WEBHOOK_URL=https://fin.example.com/api/telegram/webhook
FT_TELEGRAM_WEBHOOK_SECRET=telegram-webhook-secret
FT_TELEGRAM_POLLING_ENABLED=false

# -------------------------------
# Push Notifications (optional)
# -------------------------------
FT_PUSH_ENABLED=false
FT_PUSH_VAPID_PUBLIC_KEY=public-key-value
FT_PUSH_FIREBASE_API_KEY=firebase-api-key
FT_PUSH_FIREBASE_AUTH_DOMAIN=project.firebaseapp.com
FT_PUSH_FIREBASE_PROJECT_ID=project-id
FT_PUSH_FIREBASE_STORAGE_BUCKET=project.appspot.com
FT_PUSH_FIREBASE_MESSAGING_SENDER_ID=1234567890
FT_PUSH_FIREBASE_APP_ID=1:1234567890:web:abcdef123456
FT_PUSH_FIREBASE_MEASUREMENT_ID=G-ABCDEFG123
FT_PUSH_FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account"}

# -------------------------------
# Backup Defaults (optional)
# -------------------------------
FT_BACKUP_ENABLED=false
FT_BACKUP_PROVIDER=filesystem
FT_BACKUP_SCHEDULE_CRON=0 2 * * *
FT_BACKUP_RETENTION_DAYS=7
FT_BACKUP_DESTINATION=/fintracker/backups

# -------------------------------
# Logging and Scheduler (optional)
# -------------------------------
FT_LOG_LEVEL=INFO
FT_DEBUG_LOG=false
FT_LOG_DIR=/fintracker/logs
FT_LOG_FILE=/fintracker/logs/application.log
FT_AUDIT_LOG_FILE=/fintracker/logs/audit.log
FT_TELEGRAM_LOG_FILE=/fintracker/logs/telegram.log
FT_SCHEDULER_LOG_FILE=/fintracker/logs/scheduler.log
FT_ERROR_LOG_FILE=/fintracker/logs/error.log
FT_LOG_MAX_BYTES=10485760
FT_LOG_BACKUP_COUNT=10
SCHEDULER_RUN_TIME=5:41 AM IST
FT_NOTIFICATION_ALERT_INTERVAL_SECONDS=300

# -------------------------------
# AI (optional)
# -------------------------------
OPENAI_API_KEY=sk-xxxx

# -------------------------------
# Docker Helpers (optional)
# -------------------------------
MONGO_INITDB_DATABASE=fintracker
ME_CONFIG_MONGODB_SERVER=mongodb
ME_CONFIG_MONGODB_PORT=27017
ME_CONFIG_BASICAUTH_USERNAME=admin
ME_CONFIG_BASICAUTH_PASSWORD=change-me
ME_CONFIG_OPTIONS_EDITORTHEME=ambiance
