# MongoDB
MONGO_INITDB_DATABASE=fintracker

# Mongo Express
ME_CONFIG_MONGODB_SERVER=mongodb
ME_CONFIG_MONGODB_PORT=27017
ME_CONFIG_OPTIONS_EDITORTHEME=ambiance
ME_CONFIG_BASICAUTH_USERNAME=admin
ME_CONFIG_BASICAUTH_PASSWORD=admin

ME_CONFIG_MONGODB_ENABLE_ADMIN="true"
ME_CONFIG_MONGODB_SERVER=mongodb
ME_CONFIG_MONGODB_SSL="true"
ME_CONFIG_MONGODB_SSL_CA_FILE=/certs/ca.pem
ME_CONFIG_MONGODB_SSL_CERT_FILE=/certs/client-cert.pem

# Backend

ENV=Dev
FT_APP_NAME=FinTracker
FT_APP_VERSION=0.1
FT_MONGO_URI=mongodb://mongodb
FT_MONGO_DB_NAME=<DB Name>
FT_KEYCLOAK_URL=<Keycloak URL>
FT_KEYCLOAK_REALM=<Keycloak Realm>
FT_CLIENT_ID=<ClientID>
FT_SESSION_SECRET=super-secret
FT_BASE_URL=<Web URL>